@using Clc.BibDedupe.Web.Models
@model IEnumerable<DecisionItem>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <title>Decisions</title>
</head>
<body>
@await Html.PartialAsync("_Menu")
<table>
    <thead>
        <tr>
            <th>Left Bib</th>
            <th>Right Bib</th>
            <th>Action</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var d in Model)
{
    <tr>
        <td>@d.LeftBibId</td>
        <td>@d.RightBibId</td>
        <td>
            <form asp-action="Update" method="post">
                <input type="hidden" name="leftBibId" value="@d.LeftBibId" />
                <input type="hidden" name="rightBibId" value="@d.RightBibId" />
                <select name="action">
@foreach (DupeBibPairActions a in Enum.GetValues(typeof(DupeBibPairActions)))
{
                    <option value="@a" selected="@(a==d.Action?"selected":null)">@a</option>
}
                </select>
                <button type="submit">Save</button>
            </form>
        </td>
        <td>
            <form asp-action="Delete" method="post">
                <input type="hidden" name="leftBibId" value="@d.LeftBibId" />
                <input type="hidden" name="rightBibId" value="@d.RightBibId" />
                <button type="submit">Remove</button>
            </form>
        </td>
    </tr>
}
    </tbody>
</table>
</body>
</html>
