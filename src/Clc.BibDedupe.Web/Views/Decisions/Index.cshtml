@using Clc.BibDedupe.Web.Models
@model IEnumerable<DecisionItem>
@{
    ViewData["Title"] = "Decisions";
}

<h1>Decisions</h1>
<table class="table table-striped">
    <thead class="table-dark">
        <tr>
            <th>Left Bib</th>
            <th>Left Title</th>
            <th>Left Author</th>
            <th>Right Bib</th>
            <th>Right Title</th>
            <th>Right Author</th>
            <th>Match Type</th>
            <th>Match Value</th>
            <th>Action</th>
            <th>Review</th>
        </tr>
    </thead>
    <tbody>
@foreach (var d in Model)
{
        <tr>
            <td>@d.LeftBibId</td>
            <td>@d.LeftTitle</td>
            <td>@d.LeftAuthor</td>
            <td>@d.RightBibId</td>
            <td>@d.RightTitle</td>
            <td>@d.RightAuthor</td>
            <td>@d.MatchType</td>
            <td>@d.MatchValue</td>
            <td>@d.Action</td>
            <td>
                <a asp-action="Review" asp-route-leftBibId="@d.LeftBibId" asp-route-rightBibId="@d.RightBibId" class="btn btn-sm btn-primary">Review</a>
            </td>
        </tr>
}
    </tbody>
</table>
