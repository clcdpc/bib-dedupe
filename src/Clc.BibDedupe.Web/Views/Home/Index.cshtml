@using Clc.BibDedupe.Web.Models
@model IndexViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/clc-dedupe.css" asp-append-version="true" />
</head>
<body>
<div class="page" data-resolve-url="@Url.Action("Resolve")" data-left-bib-id="@Model.LeftBibId" data-right-bib-id="@Model.RightBibId" data-return-url="@Model.ReturnUrl">
    @await Html.PartialAsync("_Menu")
    <form id="token-form" method="post" asp-antiforgery="true" style="display:none"></form>
    <div class="frames">
        <div class="frame">
            <ul class="nav nav-tabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#leftDiv" type="button" role="tab">MARC</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#leftItems" type="button" role="tab">Items</button>
                </li>
            </ul>
            <div class="tab-content">
                <div class="tab-pane fade show active" id="leftDiv" role="tabpanel">
                    @Html.Raw(Model.LeftBibXml)
                </div>
                <div class="tab-pane fade" id="leftItems" role="tabpanel">
                    <!-- Items view placeholder -->
                </div>
            </div>
        </div>
        <div class="frame">
            <ul class="nav nav-tabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#rightDiv" type="button" role="tab">MARC</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#rightItems" type="button" role="tab">Items</button>
                </li>
            </ul>
            <div class="tab-content">
                <div class="tab-pane fade show active" id="rightDiv" role="tabpanel">
                    @Html.Raw(Model.RightBibXml)
                </div>
                <div class="tab-pane fade" id="rightItems" role="tabpanel">
                    <!-- Items view placeholder -->
                </div>
            </div>
        </div>
    </div>
    <div class="controls">
        <button data-action="@nameof(BibDupePairAction.KeepLeft)" type="button">⬅️ Keep Left</button>
        <button data-action="@nameof(BibDupePairAction.KeepBoth)" type="button">↔️ Keep Both</button>
        <button data-action="@nameof(BibDupePairAction.Skip)" type="button">⏭️ Skip</button>
        <button data-action="@nameof(BibDupePairAction.KeepRight)" type="button">➡️ Keep Right</button>
    </div>
</div>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/clc-dedupe.js" asp-append-version="true"></script>
</body>
</html>

