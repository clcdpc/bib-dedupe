@model Clc.BibDedupe.Web.Models.HomeIndexViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Log in</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="text-center mt-5">
        @if (!string.IsNullOrEmpty(Model.Message))
        {
            <div class="alert alert-danger">@Model.Message</div>
        }

        @if (!string.IsNullOrEmpty(Model.CurrentUserName))
        {
            <p class="mt-3">Signed in as <strong>@Model.CurrentUserName</strong>.</p>
        }

        <div class="d-flex flex-column flex-sm-row justify-content-center gap-2 mt-4">
            <a asp-controller="Pairs" asp-action="Index" class="btn btn-primary">Log in</a>
            @if (!string.IsNullOrEmpty(Model.CurrentUserName))
            {
                <a asp-area="MicrosoftIdentity" asp-controller="Account" asp-action="SignOut" asp-route-postLogoutRedirectUri="/" class="btn btn-outline-secondary">Sign in as a different user</a>
            }
        </div>
    </div>
</body>
</html>
