@using Clc.BibDedupe.Web.Models
@model IndexViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/clc-dedupe.css" asp-append-version="true" />
</head>
<body>
<div class="page" data-resolve-url="@Url.Action("Resolve")" data-left-bib-id="@Model.LeftBibId" data-right-bib-id="@Model.RightBibId" data-return-url="@Model.ReturnUrl">
    @await Html.PartialAsync("_Menu")
    <form id="token-form" method="post" asp-antiforgery="true" style="display:none"></form>
    <div class="frames">
        <div class="frame" id="leftDiv">
            @Html.Raw(Model.LeftBibXml)
        </div>
        <div class="frame" id="rightDiv">
            @Html.Raw(Model.RightBibXml)
        </div>
    </div>
    <div class="controls">
        <button data-action="@nameof(DupeBibPairActions.KeepLeft)" type="button">⬅️ Keep Left</button>
        <button data-action="@nameof(DupeBibPairActions.KeepBoth)" type="button">↔️ Keep Both</button>
        <button data-action="@nameof(DupeBibPairActions.Skip)" type="button">⏭️ Skip</button>
        <button data-action="@nameof(DupeBibPairActions.KeepRight)" type="button">➡️ Keep Right</button>
    </div>
</div>
<script src="~/js/clc-dedupe.js" asp-append-version="true"></script>
</body>
</html>

