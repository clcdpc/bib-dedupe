@using Clc.BibDedupe.Web.Services
@inject IDecisionStore DecisionStore
@{
    var user = Context.User?.Identity?.Name ?? string.Empty;
    var decisionCount = await DecisionStore.CountAsync(user);
}
<nav class="menu">
    <a asp-controller="Pairs" asp-action="Index">Dupe List</a>
    <a asp-controller="Decisions" asp-action="Index">Decisions <span class="badge">@decisionCount</span></a>
    <a asp-controller="Home" asp-action="Index">Current Pair</a>
</nav>
