@using Clc.BibDedupe.Web.Services
@using System.Security.Claims
@inject IDecisionStore DecisionStore
@{
    var email = Context.User?.FindFirst(ClaimTypes.Email)?.Value
        ?? Context.User?.FindFirst("preferred_username")?.Value
        ?? string.Empty;
    var decisionCount = await DecisionStore.CountAsync(email);
}
<nav class="menu nav">
    <a class="nav-link" asp-controller="Pairs" asp-action="Index">Pair List</a>
    <a class="nav-link" asp-controller="Decisions" asp-action="Index">Decisions <span class="badge">@decisionCount</span></a>
    <a class="nav-link" asp-controller="Home" asp-action="Index">Current Pair</a>
    <a class="nav-link" asp-area="MicrosoftIdentity" asp-controller="Account" asp-action="SignOut">Sign out</a>
</nav>
