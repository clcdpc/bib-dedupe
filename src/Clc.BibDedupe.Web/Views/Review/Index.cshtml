@using Clc.BibDedupe.Web.Models
@using Microsoft.AspNetCore.Html
@using Microsoft.AspNetCore.Mvc.Rendering
@model IndexViewModel
@functions {
    private sealed class ActionButton
    {
        public ActionButton(BibDupePairAction action, string label, string text, bool available)
        {
            Action = action;
            Label = label;
            Text = text;
            Available = available;
        }

        public BibDupePairAction Action { get; }
        public string Label { get; }
        public string Text { get; }
        public bool Available { get; }
    }

    private static IHtmlContent RenderActionButton(ActionButton actionButton, string unavailableActionReason)
    {
        var tagBuilder = new TagBuilder("button");
        tagBuilder.Attributes["data-action"] = actionButton.Action.ToString();
        tagBuilder.Attributes["data-label"] = actionButton.Label;
        tagBuilder.Attributes["type"] = "button";
        var availabilityValue = "true";
        if (!actionButton.Available)
        {
            availabilityValue = "false";
        }
        tagBuilder.Attributes["data-available"] = availabilityValue;

        if (!actionButton.Available)
        {
            tagBuilder.Attributes["disabled"] = "disabled";
            tagBuilder.Attributes["aria-disabled"] = "true";
            tagBuilder.Attributes["title"] = unavailableActionReason;
            tagBuilder.Attributes["data-bs-toggle"] = "tooltip";
            tagBuilder.Attributes["data-bs-title"] = unavailableActionReason;
            tagBuilder.Attributes["data-unavailable-reason"] = unavailableActionReason;
        }

        tagBuilder.InnerHtml.Append(actionButton.Text);
        return tagBuilder;
    }
}
@{ 
    Layout = null;
    var validActions = Model.ValidActions;
    var keepLeftAvailable = validActions.Contains(BibDupePairAction.KeepLeft);
    var notDuplicateAvailable = validActions.Contains(BibDupePairAction.NotDuplicate);
    var skipAvailable = validActions.Contains(BibDupePairAction.Skip);
    var keepRightAvailable = validActions.Contains(BibDupePairAction.KeepRight);
    const string unavailableActionReason = "This action conflicts with another decision in your queue.";
    var actionButtons = new[]
    {
        new ActionButton(BibDupePairAction.KeepLeft, "Keep Left", "⬅️ Keep Left", keepLeftAvailable),
        new ActionButton(BibDupePairAction.NotDuplicate, "Not Duplicate", "↔️ Not Duplicate", notDuplicateAvailable),
        new ActionButton(BibDupePairAction.Skip, "Pass", "⏭️ Pass", skipAvailable),
        new ActionButton(BibDupePairAction.KeepRight, "Keep Right", "➡️ Keep Right", keepRightAvailable)
    };
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/clc-dedupe.css" asp-append-version="true" />
</head>
<body>
<div class="action-toast-container" aria-live="polite" aria-atomic="true"></div>
<div class="page"
     data-resolve-url="@Url.Action("Resolve")"
     data-review-url="@Url.Action("Index")"
     data-left-bib-id="@Model.LeftBibId"
     data-right-bib-id="@Model.RightBibId"
     data-left-title="@Model.LeftTitle"
     data-right-title="@Model.RightTitle"
     data-re-review="@(Model.IsReReview ? "true" : "false")"
     data-re-review-action="@(Model.ExistingDecisionAction?.ToString() ?? string.Empty)">
    @{ 
        ViewData["MatchPoints"] = Model.Matches;
        ViewData["MatchSummaryTitle"] = "Match Types";
        ViewData["HoldSummary"] = new HoldSummary(Model.LeftHoldCount, Model.TotalHoldCount, Model.RightHoldCount);
    }
    @await Html.PartialAsync("_Menu")
    <form id="token-form" method="post" asp-antiforgery="true" class="token-form"></form>
    <div class="frames">
        <div class="frame">
            <div class="tab-buttons">
                <button class="tab-button active" type="button" data-tab="left-marc">MARC</button>
                <button class="tab-button" type="button" data-tab="left-items">Items (@Model.LeftItems.Count)</button>
            </div>
            <div class="tab-pane active" id="leftDiv" data-tab="left-marc">
                @Html.Raw(Model.LeftBibXml)
            </div>
            <div class="tab-pane" id="leftItems" data-tab="left-items">
                @await Html.PartialAsync("_ItemsTable", new ItemsTableViewModel { Items = Model.LeftItems, Fields = Model.ItemFields })
            </div>
        </div>
        <div class="frame">
            <div class="tab-buttons">
                <button class="tab-button active" type="button" data-tab="right-marc">MARC</button>
                <button class="tab-button" type="button" data-tab="right-items">Items (@Model.RightItems.Count)</button>
            </div>
            <div class="tab-pane active" id="rightDiv" data-tab="right-marc">
                @Html.Raw(Model.RightBibXml)
            </div>
            <div class="tab-pane" id="rightItems" data-tab="right-items">
                @await Html.PartialAsync("_ItemsTable", new ItemsTableViewModel { Items = Model.RightItems, Fields = Model.ItemFields })
            </div>
        </div>
    </div>
    <div class="controls">
        @foreach (var actionButton in actionButtons)
        {
            @RenderActionButton(actionButton, unavailableActionReason)
        }
    </div>
</div>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script src="~/js/clc-dedupe.js" asp-append-version="true"></script>
</body>
</html>
