@using Clc.BibDedupe.Web.Models
@model IndexViewModel
@{ 
    Layout = null;
    var validActions = Model.ValidActions;
    var keepLeftAvailable = validActions.Contains(BibDupePairAction.KeepLeft);
    var notDuplicateAvailable = validActions.Contains(BibDupePairAction.NotDuplicate);
    var skipAvailable = validActions.Contains(BibDupePairAction.Skip);
    var keepRightAvailable = validActions.Contains(BibDupePairAction.KeepRight);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/clc-dedupe.css" asp-append-version="true" />
</head>
<body>
<div class="action-toast-container" aria-live="polite" aria-atomic="true"></div>
<div class="page" data-resolve-url="@Url.Action("Resolve")" data-review-url="@Url.Action("Index")" data-left-bib-id="@Model.LeftBibId" data-right-bib-id="@Model.RightBibId" data-left-title="@Model.LeftTitle" data-right-title="@Model.RightTitle">
    @{ 
        ViewData["MatchPoints"] = Model.Matches;
        ViewData["MatchSummaryTitle"] = "Match Types";
        ViewData["HoldSummary"] = new HoldSummary(Model.LeftHoldCount, Model.TotalHoldCount, Model.RightHoldCount);
    }
    @await Html.PartialAsync("_Menu")
    <form id="token-form" method="post" asp-antiforgery="true" style="display:none"></form>
    <div class="frames">
        <div class="frame">
            <div class="tab-buttons">
                <button class="tab-button active" type="button" data-tab="left-marc">MARC</button>
                <button class="tab-button" type="button" data-tab="left-items">Items (@Model.LeftItems.Count)</button>
            </div>
            <div class="tab-pane active" id="leftDiv" data-tab="left-marc">
                @Html.Raw(Model.LeftBibXml)
            </div>
            <div class="tab-pane" id="leftItems" data-tab="left-items">
                @await Html.PartialAsync("_ItemsTable", new ItemsTableViewModel { Items = Model.LeftItems, Fields = Model.ItemFields })
            </div>
        </div>
        <div class="frame">
            <div class="tab-buttons">
                <button class="tab-button active" type="button" data-tab="right-marc">MARC</button>
                <button class="tab-button" type="button" data-tab="right-items">Items (@Model.RightItems.Count)</button>
            </div>
            <div class="tab-pane active" id="rightDiv" data-tab="right-marc">
                @Html.Raw(Model.RightBibXml)
            </div>
            <div class="tab-pane" id="rightItems" data-tab="right-items">
                @await Html.PartialAsync("_ItemsTable", new ItemsTableViewModel { Items = Model.RightItems, Fields = Model.ItemFields })
            </div>
        </div>
    </div>
    <div class="controls">
        <button data-action="@nameof(BibDupePairAction.KeepLeft)" data-available="@(keepLeftAvailable ? "true" : "false")" type="button" @(keepLeftAvailable ? string.Empty : "disabled=\"disabled\" aria-disabled=\"true\"")>⬅️ Keep Left</button>
        <button data-action="@nameof(BibDupePairAction.NotDuplicate)" data-available="@(notDuplicateAvailable ? "true" : "false")" type="button" @(notDuplicateAvailable ? string.Empty : "disabled=\"disabled\" aria-disabled=\"true\"")>↔️ Not Duplicate</button>
        <button data-action="@nameof(BibDupePairAction.Skip)" data-available="@(skipAvailable ? "true" : "false")" type="button" @(skipAvailable ? string.Empty : "disabled=\"disabled\" aria-disabled=\"true\"")>⏭️ Pass</button>
        <button data-action="@nameof(BibDupePairAction.KeepRight)" data-available="@(keepRightAvailable ? "true" : "false")" type="button" @(keepRightAvailable ? string.Empty : "disabled=\"disabled\" aria-disabled=\"true\"")>➡️ Keep Right</button>
    </div>
</div>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script src="~/js/clc-dedupe.js" asp-append-version="true"></script>
</body>
</html>

