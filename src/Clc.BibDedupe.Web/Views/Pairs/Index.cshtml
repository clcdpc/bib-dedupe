@using System.Linq
@using Clc.BibDedupe.Web.Models
@model PairsListViewModel
@{
    ViewData["Title"] = "Pairs";
    ViewBag.ContainerClass = "container-fluid px-4 px-lg-5";
    var visiblePairs = Model.Items.ToList();
    var totalPages = System.Math.Max(Model.TotalPages, 1);
    var currentPage = System.Math.Min(System.Math.Max(Model.Page, 1), totalPages);
    var totalPairs = System.Math.Max(Model.TotalCount, 0);
}

<div class="d-flex flex-column flex-lg-row align-items-lg-end justify-content-between gap-3 mb-4">
    <div>
        <h1 class="display-6 mb-0">Pairs</h1>
        <p class="text-muted mb-0">Review potential duplicates across the collection.</p>
    </div>
    <div class="text-lg-end text-muted small">
        Showing <strong>@visiblePairs.Count</strong> of <strong>@totalPairs</strong> pairs
    </div>
</div>

<div class="pairs-toolbar mb-4">
    <form class="row row-cols-lg-auto g-3 align-items-center" method="get">
        <div class="col-auto">
            <label for="pageSize" class="form-label fw-semibold text-uppercase small text-muted mb-0">Page Size</label>
        </div>
        <div class="col-auto">
            <input type="number" class="form-control form-control-sm" id="pageSize" name="pageSize" value="@Model.PageSize" min="1" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary btn-sm px-3">Apply</button>
        </div>
    </form>
</div>

<div class="table-responsive pairs-table-wrapper">
    <table class="table table-striped table-hover align-middle pairs-table mb-0">
        <thead>
            <tr>
                <th scope="col">Left Bib</th>
                <th scope="col">Left Details</th>
                <th scope="col">Right Bib</th>
                <th scope="col">Right Details</th>
                <th scope="col">Match Type</th>
                <th scope="col" class="text-end">Match Value</th>
                <th scope="col" class="text-center">Review</th>
            </tr>
        </thead>
        <tbody>
            @if (visiblePairs.Any())
            {
                foreach (var p in visiblePairs)
                {
                    <tr>
                        <td class="bib-column">@p.LeftBibId</td>
                        <td class="work-column">
                            <div class="work-title">@p.LeftTitle</div>
                            <div class="work-meta text-muted">@p.LeftAuthor</div>
                        </td>
                        <td class="bib-column">@p.RightBibId</td>
                        <td class="work-column">
                            <div class="work-title">@p.RightTitle</div>
                            <div class="work-meta text-muted">@p.RightAuthor</div>
                        </td>
                        <td class="text-nowrap">
                            <span class="badge bg-info text-dark">@p.MatchType</span>
                        </td>
                        <td class="text-end text-nowrap fw-semibold match-value">@p.MatchValue</td>
                        <td class="text-center">
                            <a asp-controller="Home" asp-action="Review" asp-route-leftBibId="@p.LeftBibId" asp-route-rightBibId="@p.RightBibId" asp-route-returnUrl="@Url.Action("Index", new { page = currentPage, pageSize = Model.PageSize })" class="btn btn-outline-primary btn-sm px-3">Review</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center py-5 text-muted">No pairs are available for review right now.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mt-4">
    <div class="text-muted">Page @currentPage of @totalPages</div>
    <div class="pager">
        @if (currentPage > 1)
        {
            <a class="btn btn-sm" asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-pageSize="@Model.PageSize">Prev</a>
        }
        @if (currentPage < totalPages)
        {
            <a class="btn btn-sm" asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-pageSize="@Model.PageSize">Next</a>
        }
    </div>
</div>
