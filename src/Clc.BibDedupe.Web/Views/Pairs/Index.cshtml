@using System
@using System.Linq
@using Clc.BibDedupe.Web.Controllers
@using Clc.BibDedupe.Web.Models
@model PairsListViewModel
@{
    ViewData["Title"] = "Pairs";
    ViewBag.ContainerClass = "container-fluid";
    var visiblePairs = Model.Items.ToList();
    var totalPages = System.Math.Max(Model.TotalPages, 1);
    var currentPage = System.Math.Min(System.Math.Max(Model.Page, 1), totalPages);
    var totalPairs = System.Math.Max(Model.TotalCount, 0);
    var hasHoldsRouteValue = Model.SelectedHasHolds.HasValue
        ? Model.SelectedHasHolds.Value.ToString().ToLowerInvariant()
        : null;
    var hasActiveFilters = Model.SelectedTomId is not null
        || !string.IsNullOrWhiteSpace(Model.SelectedMatchType)
        || Model.SelectedHasHolds is not null;
    var clearFiltersButtonClass = hasActiveFilters
        ? "btn btn-primary btn-sm px-3"
        : "btn btn-secondary btn-sm px-3";
}

<div class="pairs-toolbar mb-4">
    <form id="pairsFilters" class="row g-3 align-items-center" method="get">
        <input type="hidden" name="page" value="1" />
        <div class="col-12 col-lg">
            <div class="d-flex flex-wrap align-items-center gap-2">
                <div>
                    <select class="form-select form-select-sm pairs-filter-select pairs-filter-select--tom" id="tom" name="tom">
                        <option value="" selected="@(Model.SelectedTomId is null ? "selected" : null)">All TOMs</option>
                        @foreach (var tomOption in Model.TomOptions ?? Enumerable.Empty<TomOption>())
                        {
                            <option value="@tomOption.Id" selected="@(tomOption.Id == Model.SelectedTomId ? "selected" : null)">@tomOption.Description</option>
                        }
                    </select>
                </div>
                <div>
                    <select class="form-select form-select-sm pairs-filter-select pairs-filter-select--match-type" id="matchType" name="matchType">
                        <option value="" selected="@(string.IsNullOrWhiteSpace(Model.SelectedMatchType) ? "selected" : null)">All match types</option>
                        @foreach (var matchTypeOption in Model.MatchTypeOptions ?? Enumerable.Empty<string>())
                        {
                            var isSelected = string.Equals(matchTypeOption, Model.SelectedMatchType, StringComparison.OrdinalIgnoreCase);
                            <option value="@matchTypeOption" selected="@(isSelected ? "selected" : null)">@matchTypeOption</option>
                        }
                    </select>
                </div>
                <div>
                    <select class="form-select form-select-sm pairs-filter-select pairs-filter-select--holds" id="hasHolds" name="hasHolds">
                        <option value="" selected="@(Model.SelectedHasHolds is null ? "selected" : null)">All pairs</option>
                        <option value="true" selected="@(Model.SelectedHasHolds == true ? "selected" : null)">Has holds</option>
                        <option value="false" selected="@(Model.SelectedHasHolds == false ? "selected" : null)">No holds</option>
                    </select>
                </div>
                <div>
                    <button type="submit" name="clearFilters" value="true" class="@clearFiltersButtonClass" @(hasActiveFilters ? null : "disabled")>Clear filters</button>
                </div>
            </div>
        </div>
        <div class="col-12 col-lg-auto ms-lg-auto">
            <div class="text-muted small text-lg-end">
                Showing <strong>@visiblePairs.Count</strong> of <strong>@totalPairs</strong> pairs
            </div>
        </div>
    </form>
</div>

<div class="table-responsive data-table-wrapper">
    <table class="table table-striped table-hover align-middle pairs-table mb-0">
        <thead>
            <tr>
                <th scope="col">Left Bib</th>
                <th scope="col">Left Title</th>
                <th scope="col">Left Author</th>
                <th scope="col">Right Bib</th>
                <th scope="col">Right Title</th>
                <th scope="col">Right Author</th>
                <th scope="col">TOM</th>
                <th scope="col">Matches</th>
                <th scope="col" class="text-center">Review</th>
            </tr>
        </thead>
        <tbody>
            @if (visiblePairs.Any())
            {
                foreach (var p in visiblePairs)
                {
                    <tr class="pairs-row">
                        <td class="bib-column">@p.LeftBibId</td>
                        <td class="work-column">
                            <div class="work-title">@p.LeftTitle</div>
                        </td>
                        <td class="work-column">
                            <div class="work-author text-muted">@p.LeftAuthor</div>
                        </td>
                        <td class="bib-column">@p.RightBibId</td>
                        <td class="work-column">
                            <div class="work-title">@p.RightTitle</div>
                        </td>
                        <td class="work-column">
                            <div class="work-author text-muted">@p.RightAuthor</div>
                        </td>
                        <td class="tom-column">@p.TOM</td>
                        <td>
                            @await Html.PartialAsync("_MatchPoints", p.Matches)
                        </td>
                        <td class="text-center">
                            <a asp-controller="Review" asp-action="Index" asp-route-leftBibId="@p.LeftBibId" asp-route-rightBibId="@p.RightBibId" class="btn btn-sm review-btn">Review</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="9" class="text-center py-5 text-muted">No pairs are available for review right now.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mt-4">
    <div class="text-muted">Page @currentPage of @totalPages</div>
    <div class="pager">
        @if (currentPage > 1)
        {
            <a class="btn btn-sm" asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-tom="@Model.SelectedTomId" asp-route-matchType="@Model.SelectedMatchType" asp-route-hasHolds="@hasHoldsRouteValue">Prev</a>
        }
        @if (currentPage < totalPages)
        {
            <a class="btn btn-sm" asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-tom="@Model.SelectedTomId" asp-route-matchType="@Model.SelectedMatchType" asp-route-hasHolds="@hasHoldsRouteValue">Next</a>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const filterForm = document.getElementById('pairsFilters');
            if (!filterForm) {
                return;
            }

            const filterInputs = filterForm.querySelectorAll('select');
            filterInputs.forEach(function (select) {
                select.addEventListener('change', function () {
                    if (typeof filterForm.requestSubmit === 'function') {
                        filterForm.requestSubmit();
                    } else {
                        filterForm.submit();
                    }
                });
            });
        });
    </script>
}
