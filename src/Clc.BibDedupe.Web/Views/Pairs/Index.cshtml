@using Clc.BibDedupe.Web.Models
@model PairsListViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <title>Dupe Pairs</title>
</head>
<body>
@await Html.PartialAsync("_Menu")
<form method="get">
    Page Size: <input type="number" name="pageSize" value="@Model.PageSize" min="1" />
    <button type="submit">Apply</button>
</form>
<table>
    <thead>
        <tr>
            <th>Left Bib</th>
            <th>Right Bib</th>
            <th>Match Type</th>
            <th>Match Value</th>
        </tr>
    </thead>
    <tbody>
@foreach (var p in Model.Items)
{
    <tr>
        <td><a asp-controller="Home" asp-action="Index" asp-route-leftBibId="@p.LeftBibId" asp-route-rightBibId="@p.RightBibId">@p.LeftBibId</a></td>
        <td>@p.RightBibId</td>
        <td>@p.MatchType</td>
        <td>@p.MatchValue</td>
    </tr>
}
    </tbody>
</table>
<div>
    Page @Model.Page of @Model.TotalPages
    @if(Model.Page>1){<a asp-action="Index" asp-route-page="@(Model.Page-1)" asp-route-pageSize="@Model.PageSize">Prev</a>}
    @if(Model.Page<Model.TotalPages){<a asp-action="Index" asp-route-page="@(Model.Page+1)" asp-route-pageSize="@Model.PageSize">Next</a>}
</div>
</body>
</html>
