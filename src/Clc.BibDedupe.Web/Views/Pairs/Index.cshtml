@using Clc.BibDedupe.Web.Models
@model PairsListViewModel
@{
    ViewData["Title"] = "Pairs";
}

<h1>Pairs</h1>
<form class="row g-2 mb-3" method="get">
    <div class="col-auto">
        <label for="pageSize" class="col-form-label">Page Size:</label>
    </div>
    <div class="col-auto">
        <input type="number" class="form-control" id="pageSize" name="pageSize" value="@Model.PageSize" min="1" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Apply</button>
    </div>
</form>
<table class="table table-striped">
    <thead class="table-dark">
        <tr>
            <th>Left Bib</th>
            <th>Left Title</th>
            <th>Left Author</th>
            <th>Right Bib</th>
            <th>Right Title</th>
            <th>Right Author</th>
            <th>Match Type</th>
            <th>Match Value</th>
            <th>Review</th>
        </tr>
    </thead>
    <tbody>
@foreach (var p in Model.Items)
{
        <tr>
            <td>@p.LeftBibId</td>
            <td>@p.LeftTitle</td>
            <td>@p.LeftAuthor</td>
            <td>@p.RightBibId</td>
            <td>@p.RightTitle</td>
            <td>@p.RightAuthor</td>
            <td>@p.MatchType</td>
            <td>@p.MatchValue</td>
            <td>
                <a asp-controller="Home" asp-action="Review" asp-route-leftBibId="@p.LeftBibId" asp-route-rightBibId="@p.RightBibId" asp-route-returnUrl="@Url.Action("Index", new { page = Model.Page, pageSize = Model.PageSize })" class="btn btn-sm btn-primary">Review</a>
            </td>
        </tr>
}
    </tbody>
</table>
<div class="d-flex justify-content-between">
    <div>Page @Model.Page of @Model.TotalPages</div>
    <div class="pager">
        @if (Model.Page > 1)
        {
            <a class="btn btn-sm" asp-action="Index" asp-route-page="@(Model.Page - 1)" asp-route-pageSize="@Model.PageSize">Prev</a>
        }
        @if (Model.Page < Model.TotalPages)
        {
            <a class="btn btn-sm" asp-action="Index" asp-route-page="@(Model.Page + 1)" asp-route-pageSize="@Model.PageSize">Next</a>
        }
    </div>
</div>
