@using Clc.BibDedupe.Web.Models
@model PairsListViewModel
@{
    ViewData["Title"] = "Pairs";
    ViewData["LayoutContainerClass"] = "container-fluid px-4";
    ViewData["MainClass"] = "pb-4 pair-list-main";
}

<h1>Pairs</h1>
<form class="row g-2 mb-3" method="get">
    <div class="col-auto">
        <label for="pageSize" class="col-form-label">Page Size:</label>
    </div>
    <div class="col-auto">
        <input type="number" class="form-control" id="pageSize" name="pageSize" value="@Model.PageSize" min="1" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Apply</button>
    </div>
</form>
<div class="table-responsive pair-list-table shadow-sm">
    <table class="table table-striped table-hover align-middle mb-0 pairs-table">
        <thead class="table-dark">
            <tr>
                <th scope="col" class="text-nowrap">Left Bib</th>
                <th scope="col">Left Title</th>
                <th scope="col" class="text-nowrap">Left Author</th>
                <th scope="col" class="text-nowrap">Right Bib</th>
                <th scope="col">Right Title</th>
                <th scope="col" class="text-nowrap">Right Author</th>
                <th scope="col" class="text-nowrap">Match Type</th>
                <th scope="col" class="text-end text-nowrap">Match Value</th>
                <th scope="col" class="text-center text-nowrap">Review</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var p in Model.Items)
        {
            <tr>
                <td class="text-nowrap fw-semibold">@p.LeftBibId</td>
                <td class="text-break">@p.LeftTitle</td>
                <td class="text-nowrap">@p.LeftAuthor</td>
                <td class="text-nowrap fw-semibold">@p.RightBibId</td>
                <td class="text-break">@p.RightTitle</td>
                <td class="text-nowrap">@p.RightAuthor</td>
                <td class="text-nowrap"><span class="badge rounded-pill bg-secondary text-uppercase">@p.MatchType</span></td>
                <td class="text-end text-nowrap">@p.MatchValue</td>
                <td class="text-center">
                    <a asp-controller="Home" asp-action="Review" asp-route-leftBibId="@p.LeftBibId" asp-route-rightBibId="@p.RightBibId" asp-route-returnUrl="@Url.Action("Index", new { page = Model.Page, pageSize = Model.PageSize })" class="btn btn-sm btn-primary">Review</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
<div class="d-flex justify-content-between">
    <div>Page @Model.Page of @Model.TotalPages</div>
    <div class="pager">
        @if (Model.Page > 1)
        {
            <a class="btn btn-sm" asp-action="Index" asp-route-page="@(Model.Page - 1)" asp-route-pageSize="@Model.PageSize">Prev</a>
        }
        @if (Model.Page < Model.TotalPages)
        {
            <a class="btn btn-sm" asp-action="Index" asp-route-page="@(Model.Page + 1)" asp-route-pageSize="@Model.PageSize">Next</a>
        }
    </div>
</div>
