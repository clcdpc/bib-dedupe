@using Clc.BibDedupe.Web.Models
@model PairsListViewModel
@{
    ViewData["Title"] = "Pairs";
    ViewBag.MainContainerClass = "container-fluid pairs-container";
}

<h1 class="display-6 fw-semibold mb-3">Pairs</h1>
<form class="row g-2 align-items-center pairs-controls" method="get">
    <div class="col-auto">
        <label for="pageSize" class="col-form-label text-muted text-uppercase small fw-semibold">Page Size</label>
    </div>
    <div class="col-auto">
        <input type="number" class="form-control shadow-sm" id="pageSize" name="pageSize" value="@Model.PageSize" min="1" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary shadow-sm">Apply</button>
    </div>
</form>

<div class="table-responsive pairs-table-wrapper">
    <table class="table table-striped table-hover table-bordered table-sm pairs-table align-middle">
        <thead>
            <tr>
                <th scope="col">Left Bib</th>
                <th scope="col">Left Title</th>
                <th scope="col">Left Author</th>
                <th scope="col">Right Bib</th>
                <th scope="col">Right Title</th>
                <th scope="col">Right Author</th>
                <th scope="col">Match Type</th>
                <th scope="col">Match Value</th>
                <th scope="col" class="text-center">Review</th>
            </tr>
        </thead>
        <tbody>
@foreach (var p in Model.Items)
{
            <tr>
                <td class="pairs-col-id text-nowrap">@p.LeftBibId</td>
                <td class="pairs-col-title text-break">@p.LeftTitle</td>
                <td class="pairs-col-author text-break">@p.LeftAuthor</td>
                <td class="pairs-col-id text-nowrap">@p.RightBibId</td>
                <td class="pairs-col-title text-break">@p.RightTitle</td>
                <td class="pairs-col-author text-break">@p.RightAuthor</td>
                <td class="pairs-col-match-type text-nowrap">@p.MatchType</td>
                <td class="pairs-col-match-value text-end">@p.MatchValue</td>
                <td class="pairs-col-review text-center">
                    <a asp-controller="Home" asp-action="Review" asp-route-leftBibId="@p.LeftBibId" asp-route-rightBibId="@p.RightBibId" asp-route-returnUrl="@Url.Action("Index", new { page = Model.Page, pageSize = Model.PageSize })" class="btn btn-sm btn-outline-primary shadow-sm">Review</a>
                </td>
            </tr>
}
        </tbody>
    </table>
</div>

<div class="pairs-pagination d-flex flex-wrap align-items-center justify-content-between gap-2 mt-3">
    <div class="text-muted small">Page @Model.Page of @Model.TotalPages</div>
    <div class="pager">
        @if (Model.Page > 1)
        {
            <a class="btn btn-sm" asp-action="Index" asp-route-page="@(Model.Page - 1)" asp-route-pageSize="@Model.PageSize">Prev</a>
        }
        @if (Model.Page < Model.TotalPages)
        {
            <a class="btn btn-sm" asp-action="Index" asp-route-page="@(Model.Page + 1)" asp-route-pageSize="@Model.PageSize">Next</a>
        }
    </div>
</div>
